{
    "version":  "2.0.0",
    "tasks":  [
                  {
                      "label":  "01) Compile Active File -\u003e build/\u003cname\u003e.o",
                      "type":  "cppbuild",
                      "command":  "C:\\MinGW\\bin\\g++.exe",
                      "args":  [
                                   "-std=c++17",
                                   "-g",
                                   "-I${workspaceFolder}\\include",
                                   "-I${workspaceFolder}",
                                   "-c",
                                   "${file}",
                                   "-o",
                                   "${workspaceFolder}\\build\\${fileBasenameNoExtension}.o"
                               ],
                      "options":  {
                                      "cwd":  "${workspaceFolder}"
                                  },
                      "problemMatcher":  [
                                             "$gcc"
                                         ]
                  },
                  {
                      "label":  "02) Build active -\u003e \u003cname\u003e.exe (link all build/*.o)",
                      "type":  "cppbuild",
                      "command":  "C:\\MinGW\\bin\\g++.exe",
                      "args":  [
                                   "-g",
                                   "${workspaceFolder}\\build\\*.o",
                                   "-o",
                                   "${fileDirname}\\${fileBasenameNoExtension}.exe"
                               ],
                      "options":  {
                                      "cwd":  "${workspaceFolder}"
                                  },
                      "problemMatcher":  [
                                             "$gcc"
                                         ],
                      "dependsOn":  "01) Compile Active File -\u003e build/\u003cname\u003e.o",
                      "group":  {
                                    "kind":  "build",
                                    "isDefault":  true
                                }
                  },
                  {
                      "label":  "03) Build all src -\u003e nim-game.exe",
                      "type":  "shell",
                      "command":  "cmd.exe",
                      "args":  [
                                   "/d",
                                   "/c",
                                   "(if not exist \"${workspaceFolder}\\build\" mkdir \"${workspaceFolder}\\build\") \u0026\u0026 del /q \"${workspaceFolder}\\build\\*.o\" 2\u003enul \u0026\u0026 (for /r \"${workspaceFolder}\\src\" %f in (*.cpp) do (\"C:\\MinGW\\bin\\g++.exe\" -std=c++17 -g -I\"${workspaceFolder}\\include\" -I\"${workspaceFolder}\" -c \"%f\" -o \"${workspaceFolder}\\build\\%~nf.o\" || exit /b 1)) \u0026\u0026 \"C:\\MinGW\\bin\\g++.exe\" -g -static -static-libgcc -static-libstdc++ ${workspaceFolder}\\build\\*.o -o \"${workspaceFolder}\\nim-game.exe\""
                               ],
                      "options":  {
                                      "cwd":  "${workspaceFolder}"
                                  },
                      "problemMatcher":  [
                                             "$gcc"
                                         ]
                  }
              ]
}

