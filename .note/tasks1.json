{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "01) Compile Active File -> build/<name>.o",
      "type": "cppbuild",
      "command": "C:\\MinGW\\bin\\g++.exe",
      "args": [
        "-std=c++17",
        "-g",
        "-I${workspaceFolder}\\include",
        "-I${workspaceFolder}",
        "-c",
        "${file}",
        "-o",
        "${workspaceFolder}\\build\\${fileBasenameNoExtension}.o"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "02) Build active -> <name>.exe (link all build/*.o)",
      "type": "cppbuild",
      "command": "C:\\MinGW\\bin\\g++.exe",
      "args": [
        "-g",
        "${workspaceFolder}\\build\\*.o",
        "-o",
        "${workspaceFolder}\\${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": "01) Compile Active File -> build/<name>.o",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "03) Build all src -> stone-game.exe",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "(if not exist \"${workspaceFolder}\\build\" mkdir \"${workspaceFolder}\\build\") && del /q \"${workspaceFolder}\\build\\*.o\" 2>nul && for /r \"${workspaceFolder}\\src\" %f in (*.cpp) do (\"C:\\MinGW\\bin\\g++.exe\" -std=c++17 -g -I\"${workspaceFolder}\\include\" -I\"${workspaceFolder}\" -c \"%f\" -o \"${workspaceFolder}\\build\\%~nf.o\" || exit /b 1) && \"C:\\MinGW\\bin\\g++.exe\" -g ${workspaceFolder}\\build\\*.o -o \"${workspaceFolder}\\stone-game.exe\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
